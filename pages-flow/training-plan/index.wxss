.plan-container { padding: 24rpx; }
.plan-header { margin-bottom: 32rpx; }
.plan-title { font-size: 36rpx; font-weight: 700; color: #333; display: block; margin-bottom: 8rpx; }
.plan-subtitle { font-size: 26rpx; color: #999; }

.plan-days { margin-bottom: 32rpx; }
.day-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 16rpx; border: 2rpx solid transparent;
}
.day-card.current { border-color: #4A90D9; }
.day-card.completed { background: #f6ffed; }

.day-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx;
}
.day-label { font-size: 30rpx; font-weight: 600; color: #333; }
.day-status { font-size: 24rpx; color: #52c41a; }

.day-games { display: flex; flex-wrap: wrap; gap: 12rpx; }
.game-tag {
  background: #e8f4fd; color: #4A90D9;
  padding: 8rpx 20rpx; border-radius: 8rpx;
  font-size: 24rpx;
}
.day-card.completed .game-tag { background: #d9f7be; color: #389e0d; }

.plan-progress {
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  text-align: center;
}
.progress-label { font-size: 28rpx; color: #666; margin-bottom: 16rpx; display: block; }
.progress-bar {
  height: 16rpx; background: #f0f0f0; border-radius: 8rpx;
  overflow: hidden; margin-bottom: 16rpx;
}
.progress-fill {
  height: 100%; background: linear-gradient(90deg, #4A90D9, #6BB0E8);
  border-radius: 8rpx; transition: width 0.5s;
}
.progress-text { font-size: 28rpx; color: #333; font-weight: 600; }
