.breathing-container { padding: 24rpx; }
.setup-section { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; }
.difficulty-label { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.mode-options { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.mode-option {
  padding: 16rpx 32rpx; border-radius: 8rpx;
  background: #f5f5f5; font-size: 28rpx; color: #666;
  border: 2rpx solid transparent;
}
.mode-option.selected { background: #e8f4fd; color: #4A90D9; border-color: #4A90D9; }

.rounds-setting { display: flex; align-items: center; justify-content: space-between; }
.setting-label { font-size: 28rpx; color: #666; }
.rounds-display { font-size: 32rpx; font-weight: 600; color: #333; }
.stepper { display: flex; gap: 16rpx; }
.stepper-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #f0f0f0; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx;
}

.start-area { margin-top: 48rpx; }
.btn-large { width: 100%; padding: 28rpx; font-size: 34rpx; }

.breathing-area { padding: 24rpx; }
.breathing-info {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx; margin-bottom: 32rpx;
}
.round-display { font-size: 28rpx; color: #666; }
.phase-display { font-size: 32rpx; font-weight: 600; color: #4A90D9; }

.breathing-circle-container {
  display: flex; align-items: center; justify-content: center;
  height: 60vh;
}
.breathing-circle {
  width: 300rpx; height: 300rpx; border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #6BB0E8);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
}
.breathing-circle.inhale { animation: inhale 4s ease-in-out; }
.breathing-circle.exhale { animation: exhale 4s ease-in-out; }
.breathing-circle.hold { transform: scale(1.3); }

.circle-text { font-size: 36rpx; color: #fff; font-weight: 600; }

@keyframes inhale {
  0% { transform: scale(1); }
  100% { transform: scale(1.3); }
}
@keyframes exhale {
  0% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.breathing-controls { display: flex; gap: 24rpx; justify-content: center; margin-top: 32rpx; }
.breathing-controls .btn-secondary { width: 200rpx; }

.breathing-result { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; }
.result-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.result-text { font-size: 40rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.result-detail { font-size: 28rpx; color: #666; margin-bottom: 48rpx; }
.result-actions { display: flex; gap: 24rpx; }
