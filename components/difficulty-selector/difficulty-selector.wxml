<view class="difficulty-selector">
  <view class="selector-label">{{label}}</view>
  <view class="selector-options">
    <view
      class="selector-option {{item.value === selected ? 'selected' : ''}}"
      wx:for="{{options}}"
      wx:key="value"
      bindtap="onSelect"
      data-value="{{item.value}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>
</view>
