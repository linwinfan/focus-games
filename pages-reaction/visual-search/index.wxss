.game-container { padding: 24rpx; }
.instruction {
  background: #fff; border-radius: 16rpx; padding: 40rpx 32rpx;
  margin-bottom: 48rpx;
}
.inst-item { font-size: 28rpx; color: #666; margin-bottom: 12rpx; padding-left: 16rpx; }
.start-area { margin-top: 48rpx; }
.btn-large { width: 100%; padding: 28rpx; font-size: 34rpx; }

.game-area { padding: 24rpx; }
.game-info {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx; margin-bottom: 24rpx;
}
.level-display { font-size: 32rpx; font-weight: 600; color: #333; }
.timer-display { font-size: 32rpx; color: #4A90D9; }

.search-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 24rpx;
}
.search-item {
  aspect-ratio: 1; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #fff; text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3);
}
.result-area { padding: 24rpx 0; }
