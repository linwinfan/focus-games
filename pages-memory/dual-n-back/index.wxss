.game-container { padding: 24rpx; }
.setup-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.instruction { background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx; margin-bottom: 24rpx; }
.inst-item { font-size: 26rpx; color: #666; margin-bottom: 8rpx; }
.best-record { text-align: center; font-size: 26rpx; color: #666; margin: 16rpx 0; }
.best-val { font-weight: 600; color: #4A90D9; }
.start-area { margin-top: 32rpx; }
.btn-large { width: 100%; padding: 28rpx; font-size: 34rpx; }

.game-area { padding: 24rpx; }
.game-info {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx; margin-bottom: 24rpx;
}
.progress-display { font-size: 30rpx; font-weight: 600; color: #333; }
.n-label { font-size: 28rpx; color: #4A90D9; font-weight: 600; }

.nback-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 24rpx; width: 360rpx;
  margin: 0 auto 24rpx; aspect-ratio: 1;
}
.nback-cell {
  background: #f0f0f0; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
}
.nback-cell.active { background: #4A90D9; }
.position-marker {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255,255,255,0.4);
}

.letter-display {
  text-align: center; padding: 16rpx; margin-bottom: 16rpx;
}
.letter-text { font-size: 48rpx; font-weight: 700; color: #333; }

.nback-controls {
  display: flex; gap: 24rpx; justify-content: center; margin-bottom: 16rpx;
}
.nback-btn { width: 240rpx; }

.accuracy-display {
  text-align: center; font-size: 26rpx; color: #666;
}

.result-area { padding: 24rpx 0; }
.nback-stats {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 24rpx 24rpx;
}
.stat-row {
  display: flex; justify-content: space-between; padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.stat-row:last-child { border-bottom: none; }
.stat-label { font-size: 26rpx; color: #666; }
.stat-val { font-size: 26rpx; font-weight: 600; color: #333; }
