.game-container { padding: 24rpx; }
.instruction {
  background: #fff; border-radius: 16rpx; padding: 40rpx 32rpx;
  margin-bottom: 48rpx;
}
.inst-item { font-size: 28rpx; color: #666; margin-bottom: 12rpx; padding-left: 16rpx; }
.start-area { margin-top: 48rpx; }
.btn-large { width: 100%; padding: 28rpx; font-size: 34rpx; }

.game-area { padding: 24rpx; }
.game-info {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx; margin-bottom: 24rpx;
}
.level-display { font-size: 32rpx; font-weight: 600; color: #333; }
.phase-display { font-size: 28rpx; color: #4A90D9; }

.phase-content { background: #fff; border-radius: 16rpx; padding: 48rpx 32rpx; }
.number-display { text-align: center; padding: 32rpx 0; }
.number-text { font-size: 56rpx; font-weight: 700; color: #333; letter-spacing: 4rpx; }

.calc-problem {
  text-align: center; font-size: 48rpx; font-weight: 600; color: #333;
  margin-bottom: 40rpx;
}
.calc-input-area { display: flex; gap: 24rpx; justify-content: center; align-items: center; }
.calc-input {
  width: 200rpx; height: 80rpx; text-align: center; font-size: 36rpx;
  border: 2rpx solid #e8e8e8; border-radius: 12rpx;
}

.recall-prompt {
  text-align: center; font-size: 36rpx; color: #666; margin-bottom: 40rpx;
}
.recall-input-area { display: flex; gap: 24rpx; justify-content: center; align-items: center; }
.recall-input {
  width: 300rpx; height: 80rpx; text-align: center; font-size: 36rpx;
  border: 2rpx solid #e8e8e8; border-radius: 12rpx;
}

.result-area { padding: 24rpx 0; }
